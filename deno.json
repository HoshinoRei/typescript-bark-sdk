{
  "name": "@hoshinorei/bark-sdk",
  "version": "0.6.1",
  "tasks": {
    "check": "deno check --unstable-sloppy-imports src/index.ts",
    "coverage": "deno coverage coverage --lcov --output=test-result/lcov.info",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "prepublish": "deno task fmt:check && deno task lint && deno task check && deno task test && deno publish --dry-run --allow-dirty",
    "test": "deno test --unstable-sloppy-imports --coverage=coverage --junit-path=test-result/junit.xml test/unit"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "fmt": {
    "include": [
      "src/",
      "test/",
      "README.md",
      "CLAUDE.md",
      "deno.json"
    ]
  },
  "lint": {
    "include": ["src/", "test/"]
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["ES2022", "DOM"]
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "src/**/*.ts"
    ],
    "exclude": [
      ".claude/**",
      ".github/**",
      "coverage/**",
      "dist/**",
      "docs/**",
      "test-result/**",
      "test/**"
    ]
  }
}
